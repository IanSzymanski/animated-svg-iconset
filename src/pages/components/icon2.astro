---
// frontmatter for later use
---

<!-- Speaker -->
<svg id="speaker"xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide">
  <rect width="16" height="20" x="4" y="2" rx="2"/>
  <path d="M12 6h.01"/>
  <circle cx="12" cy="14" r="4"/>
  <path d="M12 14h.01"/>
</svg>

<!-- GSAP Scripting -->
<script>
    // import GSAP
    import gsap from 'gsap';

    // animate it
    gsap.from('#speaker', {
        scale: 2,
        opacity: 0,
        transformOrigin: 'center',
        duration: 0.7,
        ease: 'bounce.out',
        delay: 0.6
    });

    // Hover animations
    const speaker = document.querySelector('#speaker');

    speaker.addEventListener('mouseenter', () => {
       gsap.timeline()
        .to("#speaker", {
          scale: 1.1,
          rotate: 10,
          duration: .3,
          ease: "bounce",
          yoyo: true,
          repeat: 1,
          transformOrigin: "center center",
        })
        .to("#speaker", {
          scale: 1.3,
          rotate: -14,
          duration: .3,
          yoyo: true,
          repeat: 1,
          ease: "bounce",
        })
        .to("#speaker", {
          scale: 1.5,
          rotate: 180,
          duration: 1,
          ease: "back.out",
          yoyo: true,
          repeat: 1,
        })
        .to("#speaker", {
          scale: 1,
          duration: .7,
          delay: -.25,
          ease: "bounce.out",
        })
        .to("#speaker", {
          duration: 0.1,
          rotation: 0,
        });
    });
</script>