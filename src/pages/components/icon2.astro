// frontmatter for later use
---

<!-- Speaker -->
<svg id="speaker" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide">
  <rect width="16" height="20" x="4" y="2" rx="2"/>
  <path d="M12 6h.01"/>
  <circle cx="12" cy="14" r="4"/>
  <path d="M12 14h.01"/>
</svg>

<!-- GSAP Scripting -->
<script>
  import gsap from 'gsap';

  gsap.from('#speaker', {
    scale: 2,
    opacity: 0,
    transformOrigin: 'center',
    duration: 0.5,
    ease: 'bounce.out',
    delay: 0.6
  });

  const Speaker = document.querySelector('#speaker');

  Speaker.addEventListener('mouseenter', () => {
    gsap.timeline()
      .to('#speaker', {
        stroke: '#2DCBC3',
        duration: .6,
        ease: 'back'
      })
      .to('#speaker', {
        scale: 1.1,
        rotate: 10,
        duration: 0.3,
        ease: 'bounce',
        yoyo: true,
        repeat: 1,
        transformOrigin: 'center center',
        delay: -0.6
      })
      .to('#speaker', {
        scale: 1.3,
        rotate: -14,
        duration: 0.3,
        yoyo: true,
        repeat: 1,
        ease: 'bounce'
      })
      .to('#speaker', {
        scale: 1.5,
        rotate: 360,
        duration: 1,
        ease: 'back.out',
      })
      .to('#speaker', {
        scale: 1,
        duration: 0.7,
        delay: -0.25,
        ease: 'bounce.out'
      })
      .to('#speaker', {
        duration: 0,
        rotation: 0
      })
      .to('#speaker', {
        stroke: '#f8f8f8',
        duration: 1,
        ease: 'back',
        delay: -0.5
      });
  });
</script>