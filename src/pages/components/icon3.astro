---

<!-- Track List -->

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="list" class="lucide">
  <path class="top-line" d="M16 5H3"/>
  <path class="mid-line"d="M11 12H3"/>
  <path class="bottom-line" d="M11 19H3"/>
  <g class="note">
  <path d="M21 16V5"/>
    <circle cx="18" cy="16" r="3"/>
  </g>
      
    </svg>

<!-- GSAP Scripting -->
<script>
    import gsap from 'gsap';

    gsap.from('#list', {
        x: -10,
        opacity: 0,
        duration: 0.5,
        stagger: 0.1,
        ease: 'power3.out',
        delay: 0.7
    });

    // Hover animations
    const list = document.querySelector('#list');

    list.addEventListener('mouseenter', () => {
        gsap.timeline()
.to(".top-line, .mid-line, .bottom-line", { 
  scaleX: .4,
  duration: .3,
  ease: "back",
  transformOrigin: "left center",
})
.to(".top-line, .mid-line, .bottom-line", { 
  scaleX: 1,
  duration: .15,
  stagger: 0.03,
  ease: "back",
  transformOrigin: "left center",
  yoyo: true,
  repeat: 7,
})
.to(".top-line, .mid-line, .bottom-line", { 
  scaleX: 1,
  duration: .3,
  stagger: 0.01,
  ease: "back",
  transformOrigin: "left center",
})
.to(".note", { 
  scale: 1.2,
  ease: "bounce",
  duration: .22,
  transformOrigin: "center center",
  yoyo: true,
  repeat: 7,
  delay: -2
});
    });
</script>
