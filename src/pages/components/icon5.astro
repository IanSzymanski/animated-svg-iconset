<!-- Wave -->

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="wave" class="lucide">
    <path d="M2 13a2 2 0 0 0 2-2V7a2 2 0 0 1 4 0v13a2 2 0 0 0 4 0V4a2 2 0 0 1 4 0v13a2 2 0 0 0 4 0v-4a2 2 0 0 1 2-2"/>
</svg>

<!-- GSAP Scripting -->
<script>
    import gsap from 'gsap';

    gsap.from('#wave', {
        rotate: -100,
        scale: .5,
        opacity: 0,
        transformOrigin: 'center center',
        ease: "back",
        duration: .5,
        delay: 0.9
    });

    // Hover animations
    const wave = document.querySelector('#wave');

    wave.addEventListener('mouseenter', () => {
        gsap.timeline()
.to("#wave", { 
  scaleY: -1.4,
  scaleX: .7,
  duration: 1, 
  ease: "back"
})
.to("#wave", { 
  scaleY: 1,
  scaleX: 1,
  duration: 1, 
  delay: -.25,
  ease: "back.out",
});
    });
</script>
