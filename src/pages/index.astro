---
// server side code at build time
import '../styles/icons.css';
import Lineform from './components/icon1.astro'
import Speaker from './components/icon2.astro'
import List from './components/icon3.astro'
import Volume from './components/icon4.astro'
import Wave from './components/icon5.astro'
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet"> 
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Squid Icon Set</title>
	</head>
	<body>
 <h1>SQUID ICON SET</h1>
		<!-- Load icons as separate components -->
		<div class="icon-grid">
			<Lineform />
			<Speaker />
			<List />
			<Volume />
			<Wave />
		</div>

	</body>
</html>
